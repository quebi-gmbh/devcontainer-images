{
  "_comment": "Build config for rebuilding devcontainer images from upstream source (escaping MCR). Variants and alias tags mirror upstream's manifest.json tag scheme so our GHCR tags drop-in for the MCR ones. Bump upstream.sha to track new upstream releases (Renovate-friendly).",
  "upstream": {
    "repo": "devcontainers/images",
    "sha": "a810d5ce54b478bd5f5e1b37d7cc771f6f5bf496"
  },
  "baseMirror": "mirror.gcr.io/library",
  "variants": [
    "24-trixie", "22-trixie", "20-trixie",
    "24-bookworm", "22-bookworm", "20-bookworm",
    "24-bullseye", "22-bullseye", "20-bullseye"
  ],
  "aliases": {
    "latest": "24-trixie",
    "trixie": "24-trixie",
    "24": "24-trixie",
    "22": "22-trixie",
    "20": "20-trixie",
    "bookworm": "24-bookworm",
    "bullseye": "24-bullseye"
  },
  "images": [
    {
      "src": "javascript-node",
      "name": "devcontainer-javascript-node",
      "fromKind": "dockerhub-node",
      "comment": "FROM node:<variant> (Docker Hub) -> mirror.gcr.io/library/node:<variant>"
    },
    {
      "src": "typescript-node",
      "name": "devcontainer-typescript-node",
      "fromKind": "javascript-node",
      "needs": "devcontainer-javascript-node",
      "comment": "FROM mcr.../javascript-node:4-<variant> -> our ghcr.io/<owner>/devcontainer-javascript-node:<variant>"
    }
  ]
}
